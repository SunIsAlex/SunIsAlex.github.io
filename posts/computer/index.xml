&lt;pre tabindex="0" class="chroma"&gt;&lt;code class="language-shell" data-lang="shell"&gt;&lt;span class="line"&gt;&lt;span class="cl"&gt;grep wp-admin /var/log/nginx/access.log &lt;span class="p"&gt;|&lt;/span&gt; cat -n
